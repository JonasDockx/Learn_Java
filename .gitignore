# --- Compiled Java output ---
# .class files are bytecode — regenerated by javac, never committed.
*.class

# --- Build tool output (you'll meet these in later lessons) ---
target/          # Maven build output
build/           # Gradle build output
*.jar            # packaged archives
*.war

# --- IDE / editor noise ---
.idea/           # IntelliJ
.vscode/         # VS Code (keep if you share settings; ignoring by default)
*.iml

# --- OS clutter ---
Thumbs.db        # Windows
.DS_Store        # macOS

# --- Secrets: NEVER commit these ---
# Keys, tokens, passwords, .env files. Once pushed, treat them as compromised.
*.pem
*.key
id_rsa
id_rsa.pub
.env

# I will also ignore .agents and .claude, this was not made by me
.agents/
.claude/